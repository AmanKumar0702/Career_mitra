# =====================================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local
# =====================================================

# MongoDB — use local instance OR MongoDB Atlas
# Local:  mongodb://localhost:27017/careermitra
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/careermitra
MONGODB_URI=mongodb://localhost:27017/careermitra

# NextAuth — must be a long random string (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — leave blank to skip)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI for AI chatbot (optional — leave blank to skip)
OPENAI_API_KEY=

# Groq for AI chatbot (faster & free — recommended)
# Get key at https://console.groq.com
GROQ_API_KEY=